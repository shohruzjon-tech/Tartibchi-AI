{
  "name": "queue-system",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up -d",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:full": "npm run dev:docker && turbo run dev",
    "prod:up": "docker compose -f docker-compose.yml --env-file .env.production up -d --build",
    "prod:down": "docker compose -f docker-compose.yml down",
    "prod:logs": "docker compose -f docker-compose.yml logs -f",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "microservices/*"
  ]
}
