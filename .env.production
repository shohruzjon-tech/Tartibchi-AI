# ============================================
# Production Environment Variables
# Copy this file and set real values
# ============================================

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Eskiz SMS (https://eskiz.uz)
ESKIZ_EMAIL=your-eskiz-email
ESKIZ_PASSWORD=your-eskiz-password

# Public URLs
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://ws.yourdomain.com
