# ===========================================
# Queue System - Environment Variables Template
# ===========================================

# General
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://admin:admin123@localhost:27017/queue_system?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service Ports
GATEWAY_PORT=5000
ACCOUNTS_SERVICE_PORT=5001
QUEUE_SERVICE_PORT=5002
NOTIFICATION_SERVICE_PORT=5003
ANALYTICS_SERVICE_PORT=5004
TELEGRAM_SERVICE_PORT=5005
WEBSOCKET_SERVICE_PORT=5006

# Service Hosts (for TCP connections from gateway)
ACCOUNTS_SERVICE_HOST=localhost
QUEUE_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_HOST=localhost
ANALYTICS_SERVICE_HOST=localhost
TELEGRAM_SERVICE_HOST=localhost
WEBSOCKET_SERVICE_HOST=localhost

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRATION=7d

# SMS (Eskiz)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_BASE_URL=https://notify.eskiz.uz

# Telegram
TELEGRAM_BOT_TOKEN=

# Next.js CRM
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5006
NEXT_PUBLIC_DEFAULT_LOCALE=uz
